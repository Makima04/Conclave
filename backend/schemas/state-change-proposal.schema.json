{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conclave.dev/schemas/state-change-proposal.schema.json",
  "title": "StateChangeProposal",
  "description": "State change proposal for the two-phase commit system. Agents produce proposals; Runtime validates and commits based on risk level.",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "proposed_by", "risk", "changes"],
  "properties": {
    "type": {
      "const": "state_change_proposal"
    },
    "proposed_by": {
      "type": "string",
      "minLength": 1,
      "description": "Agent/node ID that produced this proposal"
    },
    "risk": {
      "$ref": "https://conclave.dev/schemas/common.schema.json#/$defs/RiskLevel"
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ChangeEntry"
      }
    }
  },
  "$defs": {
    "ChangeEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "target", "to"],
      "properties": {
        "op": {
          "type": "string",
          "enum": ["update", "add", "remove"]
        },
        "target": {
          "type": "string",
          "description": "Dot-path to state key, e.g. character.archivist.relationship.player.trust"
        },
        "from": {},
        "to": {},
        "evidence_turns": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
